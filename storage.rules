rules_version = '2';

// ============================================================
// Credibly — Cloud Storage security rules
// User assets live under users/{uid}/... and are publicly
// readable (profile images) but only owner-writable.
//
// Receipt uploads from anonymous funnel visitors live under
// payment_receipts/{ownerId}/... — strict MIME + size validation
// substitutes for auth (no user account at upload time).
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // ---- Credibly user assets ----
    // Profile photos, gallery, banners, etc. Public read so visitors
    // can see them; only the owner can write, and only image files
    // under 5 MB.
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && isValidImage();
    }

    // ---- Manual payment receipts ----
    // Anonymous visitors upload a receipt image when they pay through
    // a PaymentSection. After upload the client calls getDownloadURL()
    // to get the URL to persist on the Firestore submission doc —
    // that call requires READ permission, so we have to allow it for
    // anonymous visitors. We accept the trade-off because:
    //
    //   1. Filenames use uid("rcpt") — random and unguessable
    //   2. URLs only land in payment_submissions Firestore docs that
    //      are owner-restricted (no public listing)
    //   3. Files are scoped to /{ownerId}/ so cross-owner discovery
    //      isn't possible
    //
    // Write is still locked to anonymous CREATE with strict MIME +
    // size validation; update/delete require the owner.
    match /payment_receipts/{ownerId}/{allPaths=**} {
      allow read: if true;
      allow create: if isValidImage();
      allow update, delete: if isSignedIn()
        && request.auth.uid == ownerId;
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
