rules_version = '2';

// ============================================================
// Credibly — Cloud Storage security rules
// User assets live under users/{uid}/... and are publicly
// readable (profile images) but only owner-writable.
//
// Receipt uploads from anonymous funnel visitors live under
// payment_receipts/{ownerId}/... — strict MIME + size validation
// substitutes for auth (no user account at upload time).
//
// Legacy FitPal / Quiz rules are kept inline because this bucket
// is shared with that project. Removing them here would lock out
// FitPal's admin uploads on next deploy.
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    /* FitPal admin uid — separate project sharing this storage
       bucket. Hardcoded because FitPal doesn't have a Firestore
       roles collection to check. Update if the admin uid changes. */
    function isFitpalAdmin() {
      return request.auth != null
        && request.auth.uid == "5CIQlUntrjOphUvpdW7Es0bj7RB2";
    }

    // ---- Credibly user assets ----
    match /users/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && isValidImage();
    }

    // ---- Manual payment receipts ----
    // Anonymous visitors upload a receipt image when they pay
    // through a PaymentSection. Files are scoped to the owner's
    // bucket so cross-owner access is impossible. Strict size + MIME
    // limits prevent abuse: 5 MB cap, images only. The Firestore doc
    // that references the file requires fields including the
    // receiptUrl, so the create flow has a natural rate-limit
    // (one Firestore write per upload).
    match /payment_receipts/{ownerId}/{allPaths=**} {
      allow read: if isSignedIn() && request.auth.uid == ownerId;
      allow create: if isValidImage();
      allow update, delete: if isSignedIn()
        && request.auth.uid == ownerId;
    }

    // ---- FitPal assets (legacy — separate project shares this bucket) ----
    match /fitpal/{allPaths=**} {
      allow read: if true;
      allow write: if isFitpalAdmin();
    }

    // ---- Quiz assets (legacy) ----
    match /quizzes/{quizId}/{allPaths=**} {
      allow read: if true;
      allow write: if isFitpalAdmin();
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
