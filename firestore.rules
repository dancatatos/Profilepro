rules_version = '2';

// ============================================================
// Credibly — Firestore security rules
// Role-based access. Profiles are public-readable; everything
// else is owner-scoped. Admin role is read from the user doc.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Users ----
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Saved-build locker — strictly owner-only.
      match /savedBuilds/{buildId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---- Profiles (public read) ----
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Leads (anyone can submit, owner can read, admin can list all) ----
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['ownerId', 'profileId', 'name']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Analytics events (anyone can log, owner can read) ----
    match /analytics_events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['ownerId', 'profileId', 'type']);
      allow read, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- AI usage counters (server-only) ----
    // Per-day per-user docs (id: `${uid}__${YYYY-MM-DD}`) that track
    // call count + tokens for quota enforcement. Only the Admin SDK
    // writes here from API routes — clients have NO access. If we
    // later want to show "X of Y AI calls today" in the dashboard
    // we'll add an owner read rule; right now there's no client read
    // path so we keep it locked tight.
    match /ai_usage/{usageId} {
      allow read, write: if false;
    }

    // ---- AI generation history ----
    match /ai_generations/{genId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow read, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- Templates (public read, admin-managed) ----
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Shared builds (published profile templates, resolved by code) ----
    match /sharedBuilds/{buildId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Funnels (public-readable mini sales funnels) ----
    match /funnels/{funnelId} {
      allow read, list: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Shared funnels (funnels published with a share code) ----
    match /sharedFunnels/{funnelId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Media assets ----
    match /media_assets/{assetId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Subscriptions (server / admin managed) ----
    match /subscriptions/{subId} {
      allow read: if isOwner(subId) || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Settings / feature flags (public read, admin-managed) ----
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Affiliate accounts (uid-keyed, payout-editable by self) ----
    // Doc id = affiliate's Firebase Auth uid. The affiliate can read
    // and update their own row (e.g. payout details, display name).
    // Admin creates/deletes rows; admin reads everyone for the
    // affiliate management dashboard.
    match /affiliates/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ---- Affiliate invites (token-keyed) ----
    // Doc id = the random invite token. Anyone with the token (i.e.
    // anyone who clicked the invite link) can read it to render the
    // accept-invite page — the token IS the secret. Admin creates &
    // deletes. The invitee marks accepted via update once signed in.
    match /affiliate_invites/{token} {
      allow read: if true;
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() || isAdmin();
    }

    // ---- Affiliate click logs (anonymous create, admin read) ----
    // Created when a visitor lands on /r/<code>. PII-free — just code
    // + timestamp + landing page. Admin reads aggregated stats; nobody
    // updates or deletes (write-once audit trail).
    match /affiliate_clicks/{clickId} {
      allow create: if request.resource.data.keys().hasAll(['code']);
      allow read, list: if isAdmin();
      allow update, delete: if false;
    }

    // ---- Commission ledger (affiliate reads own, admin manages all) ----
    // Created by the server-side admin upgrade flow when a referred
    // user is upgraded or renewed. The owning affiliate can read their
    // own rows for the earnings dashboard. Admins can also mark
    // commissions paid / reversed via update.
    match /commissions/{commissionId} {
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.affiliateId == request.auth.uid);
      allow create, update, delete: if isAdmin();
    }

    // ---- Manual Payment Submissions ----
    // Anonymous visitors create submissions when they upload a
    // receipt through a PaymentSection. Owner reads/updates only
    // their own submissions. Admin sees everything for support.
    // Required fields enforced at create-time so spam writes are
    // shaped correctly (Firestore can't validate file size — that's
    // enforced by Storage rules + client compression).
    match /payment_submissions/{submissionId} {
      allow create: if request.resource.data.keys().hasAll([
        'ownerId', 'visitorName', 'amount', 'currency', 'receiptUrl',
        'paymentMethodId', 'status', 'submittedAt'
      ]) && request.resource.data.status == 'pending';
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ---- Follow-Up Pipelines (owner-scoped + share-code lookup) ----
    // The owner has full CRUD on their pipelines. Any signed-in user
    // can list/read for the "clone by share code" path — security
    // there comes from the random share code being unguessable
    // (same pattern as sharedBuilds and sharedFunnels). Pipelines
    // hold their stages inline so no subcollection rule needed.
    match /pipelines/{pipelineId} {
      allow read, list: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Credibly University — topic catalogue (admin-managed) ----
    // Any signed-in user can read the topic list (they need it to
    // render /university). Only admins can create / update / delete
    // — they're the curriculum owners. This was missing in the
    // original rules deploy, which is why "Save course" was failing
    // with permission-denied for the admin save path.
    match /university_topics/{topicId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ---- Web push subscriptions ----
    // One doc per (user, device). Owner CRUDs their own; admin reads
    // all for support. The cron job uses the Firebase Admin SDK,
    // which bypasses these rules entirely. Doc id is deterministic
    // (`${uid}__${endpointTail}`) so re-subscribing from the same
    // browser upserts instead of duplicating.
    match /push_subscriptions/{subId} {
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ---- Credibly University — lesson completion log (per-user) ----
    // Each doc id is `${userId}__${lessonId}`. Users can only touch
    // their own progress; admins can read/list for support.
    match /university_progress/{progressId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin()
        || (isSignedIn() && request.query.limit <= 500);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ---- Trainings (user-owned courses) ----
    // Trainings are public-readable so the /{username}/t/{slug}
    // landing page renders for anonymous visitors who haven't
    // activated yet. Owner has full CRUD. Same shape as funnels.
    match /trainings/{trainingId} {
      allow read, list: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Training access (per-user unlock records) ----
    // The LEARNER creates their own access record when activating a
    // code. The OWNER of the training reads them all for the
    // Learners tab. Doc id format: `${userId}__${trainingId}` so
    // re-activation upserts instead of duplicating.
    match /training_access/{accessId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && (
              resource.data.userId == request.auth.uid
              || resource.data.ownerId == request.auth.uid
           ));
      allow list: if isAdmin() || isSignedIn();
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if false;
    }

    // ---- Training progress (per-lesson completion log) ----
    // Each doc id is `${userId}__${lessonId}`. Same pattern as
    // university_progress — learner has full control over their own
    // rows, owner reads their training's progress via Learners tab.
    match /training_progress/{progressId} {
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ---- Team spaces (Events add-on) ----
    // Public-readable so the join page can render the team name +
    // banner anonymously before the visitor signs up. Owner has full
    // CRUD on their own spaces. Add-on gating is enforced in the
    // CLIENT (sidebar visibility + create-button gate) — Firestore
    // rules only enforce ownership.
    match /team_spaces/{spaceId} {
      allow read, list: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Team memberships ----
    // Doc id: `${userId}__${teamSpaceId}`. Members create their own
    // record when joining; both the member AND the team owner can
    // read it (the leader needs to see their member list).
    match /team_memberships/{membershipId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && (
              resource.data.userId == request.auth.uid
              || resource.data.ownerId == request.auth.uid
           ));
      allow list: if isAdmin() || isSignedIn();
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update: if false;
    }

    // ---- Team events ----
    // Public-readable so anonymous join-event-by-QR can render the
    // event preview before signup. Owner CRUDs their events; anyone
    // signed in can list (filtering by teamSpaceId enforced in app).
    match /team_events/{eventId} {
      allow read, list: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Event notifications (cron dedup — server-only) ----
    // Per-event dedup record written by /api/cron/event-reminders so
    // re-firing the cron same-day is a no-op. Clients never read or
    // write this collection.
    match /event_notifications/{notifId} {
      allow read, write: if false;
    }

    // ---- Event RSVPs ----
    // Members CRUD their own; team owner can read the full list to
    // see who's attending.
    match /event_rsvps/{rsvpId} {
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (isSignedIn() && exists(
              /databases/$(database)/documents/team_spaces/$(resource.data.teamSpaceId))
            && get(/databases/$(database)/documents/team_spaces/$(resource.data.teamSpaceId)).data.ownerId == request.auth.uid);
      allow list: if isAdmin() || isSignedIn();
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // ---- Appointment slot markers (public, PII-free availability) ----
    match /bookingSlots/{slotId} {
      allow read, list: if true;
      allow create: if request.resource.data.keys().hasAll(['profileId', 'ownerId', 'date', 'time']);
      allow update: if false;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Appointment bookings (owner-only read — holds visitor contact info) ----
    match /bookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll(['profileId', 'ownerId', 'date', 'time', 'name']);
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update: if false;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }
  }
}
