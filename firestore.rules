rules_version = '2';

// ============================================================
// Credibly — Firestore security rules
// Role-based access. Profiles are public-readable; everything
// else is owner-scoped. Admin role is read from the user doc.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ---- Users ----
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();

      // Saved-build locker — strictly owner-only.
      match /savedBuilds/{buildId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ---- Profiles (public read) ----
    match /profiles/{profileId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Leads (anyone can submit, owner can read, admin can list all) ----
    match /leads/{leadId} {
      allow create: if request.resource.data.keys().hasAll(['ownerId', 'profileId', 'name']);
      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Analytics events (anyone can log, owner can read) ----
    match /analytics_events/{eventId} {
      allow create: if request.resource.data.keys().hasAll(['ownerId', 'profileId', 'type']);
      allow read, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- AI generation history ----
    match /ai_generations/{genId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow read, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---- Templates (public read, admin-managed) ----
    match /templates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Shared builds (published profile templates, resolved by code) ----
    match /sharedBuilds/{buildId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Funnels (public-readable mini sales funnels) ----
    match /funnels/{funnelId} {
      allow read, list: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Shared funnels (funnels published with a share code) ----
    match /sharedFunnels/{funnelId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Media assets ----
    match /media_assets/{assetId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Subscriptions (server / admin managed) ----
    match /subscriptions/{subId} {
      allow read: if isOwner(subId) || isAdmin();
      allow write: if isAdmin();
    }

    // ---- Settings / feature flags (public read, admin-managed) ----
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---- Credibly University — topic catalogue (admin-managed) ----
    // Any signed-in user can read the topic list (they need it to
    // render /university). Only admins can create / update / delete
    // — they're the curriculum owners. This was missing in the
    // original rules deploy, which is why "Save course" was failing
    // with permission-denied for the admin save path.
    match /university_topics/{topicId} {
      allow read, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // ---- Credibly University — lesson completion log (per-user) ----
    // Each doc id is `${userId}__${lessonId}`. Users can only touch
    // their own progress; admins can read/list for support.
    match /university_progress/{progressId} {
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isAdmin()
        || (isSignedIn() && request.query.limit <= 500);
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ---- Appointment slot markers (public, PII-free availability) ----
    match /bookingSlots/{slotId} {
      allow read, list: if true;
      allow create: if request.resource.data.keys().hasAll(['profileId', 'ownerId', 'date', 'time']);
      allow update: if false;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // ---- Appointment bookings (owner-only read — holds visitor contact info) ----
    match /bookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll(['profileId', 'ownerId', 'date', 'time', 'name']);
      allow read, list: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow update: if false;
      allow delete: if isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }
  }
}
