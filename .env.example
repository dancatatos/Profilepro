# ============================================================
# Credibly — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# See README.md for a step-by-step setup walkthrough.
# ============================================================

# ---- Firebase Web App config (Project settings > Your apps > Web) ----
# These are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- App config ----
# Public base URL of the deployed app (used for share links + QR codes).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Gemini AI (server-side only — NEVER prefix with NEXT_PUBLIC) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default model. gemini-2.5-flash is fast + supports JSON schema output.
GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase Admin (server-side) ----
# REQUIRED for the renewal-reminder cron. Generate at Firebase Console →
# Project Settings → Service Accounts → Generate new private key. Open the
# downloaded JSON and copy the three values below.
# IMPORTANT: in Vercel, paste the entire private_key INCLUDING the
# -----BEGIN/END PRIVATE KEY----- lines. Vercel preserves \n as literal,
# which our admin client unescapes at load time — so paste the raw value.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---- Email (Resend) ----
# API key from https://resend.com/api-keys
RESEND_API_KEY=
# From address used for outgoing emails. Falls back to onboarding@resend.dev
# (works without domain verification but unprofessional). Once your domain
# is verified in Resend, set this to: Credibly <noreply@crediblyai.com>
EMAIL_FROM=

# ---- Cron ----
# Random secret string used to authenticate Vercel Cron requests.
# Generate with: openssl rand -hex 32  (or any random-string generator)
# Vercel automatically attaches "Authorization: Bearer ${CRON_SECRET}"
# when calling your cron routes — the cron handler rejects anything else.
CRON_SECRET=
