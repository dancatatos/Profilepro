# ============================================================
# Credibly — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# See README.md for a step-by-step setup walkthrough.
# ============================================================

# ---- Firebase Web App config (Project settings > Your apps > Web) ----
# These are safe to expose to the browser (NEXT_PUBLIC_*).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---- App config ----
# Public base URL of the deployed app (used for share links + QR codes).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Gemini AI (server-side only — NEVER prefix with NEXT_PUBLIC) ----
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default model. gemini-2.5-flash is fast + supports JSON schema output.
GEMINI_MODEL=gemini-2.5-flash

# ---- Firebase Admin (server-side, for API routes that need admin SDK) ----
# Optional for the foundation build. Used later by Cloud Functions / admin tasks.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
